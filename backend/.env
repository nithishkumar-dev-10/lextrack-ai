# ─────────────────────────────────────────
#  LexTrack-AI  —  Environment Variables
# ─────────────────────────────────────────

# Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_YOUR_ACTUAL_KEY_HERE

# Gemini model to use
GEMINI_MODEL=gemini-1.5-flash

# App settings
APP_NAME=LexTrack-AI
APP_VERSION=2.0.0
DEBUG=True

# Database
DATABASE_URL=sqlite:///./lextrack.db

# CORS - use * for development
ALLOWED_ORIGINS=*

# Self-Doubt Engine threshold
# If confidence score is below this, warn the user
CONFIDENCE_THRESHOLD=60